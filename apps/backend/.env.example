# ─── Newton Academy Backend — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=8668127129:AAGTlH01Dd0OPbfjvu-8yu-PVF5-tGfLNi8
BOT_USERNAME=YourBotName

# Set this to your server URL for webhook mode (comment out for polling)
# WEBHOOK_URL=https://your-domain.com/bot-webhook

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/newtonbot

# ─── Redis (BullMQ) ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ─── Admin Panel Auth ────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars

# URL of the Next.js admin panel (for CORS)
ADMIN_PANEL_URL=https://admin.newton.uz

# ─── Swagger (API Docs) ──────────────────────────────────────────────────────
# Set to 'true' to enable Swagger in production (default: only in dev)
SWAGGER_ENABLED=false

# ─── Google Sheets Integration ───────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── Admin User Seed ─────────────────────────────────────────────────────────
# Used by: npx ts-node -r tsconfig-paths/register scripts/seed-admin.ts
ADMIN_EMAIL=admin@newton.uz
ADMIN_PASSWORD=ChangeMe@2024!
ADMIN_NAME=Newton Admin
